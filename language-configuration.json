{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""]
  ],
  "wordPattern": "[^\\s()\"]+",
  "indentationRules": {
    "increaseIndentPattern": "\\((?!.*\\)\\s*$)",
    "decreaseIndentPattern": "^\\s*\\)"
  },
  "onEnterRules": [
    {
      "beforeText": "\\(.*[^)]$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "folding": {
    "markers": {
      "start": "\\(",
      "end": "\\)"
    }
  }
}
